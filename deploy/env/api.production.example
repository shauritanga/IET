NODE_ENV=production
PORT=3000
SWAGGER_ENABLED=false

APP_URL=https://api.iet.or.tz
API_URL=https://api.iet.or.tz/api/v1
ENGINEER_PORTAL_URL=https://members-portal.iet.or.tz
ADMIN_PORTAL_URL=https://admin-portal.iet.or.tz
FRONTEND_ORIGINS=https://members-portal.iet.or.tz,https://admin-portal.iet.or.tz

DATABASE_ENABLED=true
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=iet_user
DB_PASSWORD=change_me
DB_NAME=iet_db

JWT_SECRET=replace_with_at_least_32_random_chars
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=replace_with_another_32_random_chars
JWT_REFRESH_EXPIRATION=7d
ENCRYPTION_KEY=replace_with_32_character_key!!

THROTTLE_TTL=60
THROTTLE_LIMIT=100

SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@iet.or.tz
EMAIL_FROM_NAME=IET Tanzania
SMTP_TLS_REJECT_UNAUTHORIZED=false

SMS_SENDER_ID=IET
BEEM_API_KEY=
BEEM_SECRET_KEY=
BEEM_SOURCE_ADDR=IET

DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_ENDPOINT=
DO_SPACES_REGION=sfo3
DO_SPACES_BUCKET=
DO_SPACES_CDN_URL=

# Selcom hosted checkout (card + mobile money) — the platform's payment gateway.
# Sandbox base: https://apigwtest2.selcommobile.com  Production: https://apigw.selcommobile.com
SELCOM_BASE_URL=https://apigw.selcommobile.com
SELCOM_API_KEY=
SELCOM_API_SECRET=
SELCOM_VENDOR=
# Bearer token Selcom sends in C2B webhook Authorization header (rejects if unset)
SELCOM_WEBHOOK_TOKEN=
SELCOM_TIMEOUT_MS=15000
# Where Selcom bounces the buyer after payment; blank => members-portal callback
SELCOM_REDIRECT_URL=
SELCOM_CANCEL_URL=

APPLICATION_FEE_GRADUATE=500
APPLICATION_FEE_STANDARD=1000
