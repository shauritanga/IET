# ============================================
# IET Management System - Environment Configuration
# ============================================
# Copy this file to .env for native-host runs.
# Docker development also reads .env, but the defaults below are already safe
# for the local compose stack.

# Application
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
API_URL=http://localhost:3000/api/v1
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4000,http://127.0.0.1:4000,http://localhost:4100,http://127.0.0.1:4100,http://192.168.1.194:4000,http://192.168.1.194:4100

# ============================================
# DATABASE
# ============================================
DATABASE_ENABLED=true
DB_HOST=localhost
DB_PORT=5435
DB_USERNAME=postgres
DB_PASSWORD=dev_password
DB_NAME=iet_db

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=dev_jwt_secret_key_at_least_32_chars_long
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=dev_refresh_secret_key_at_least_32_chars
JWT_REFRESH_EXPIRATION=7d

# ============================================
# RATE LIMITING
# ============================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ============================================
# ENCRYPTION (for 2FA secrets)
# ============================================
ENCRYPTION_KEY=dev_32_char_encryption_key_here!

# ============================================
# EMAIL SERVICE (cPanel Webmail / SMTP)
# ============================================
# Get SMTP settings from cPanel → Email Accounts → Connect Devices
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@iet.or.tz
EMAIL_FROM_NAME=IET Tanzania
# Set to false if cPanel uses a self-signed SSL certificate
SMTP_TLS_REJECT_UNAUTHORIZED=false

# ============================================
# SMS SERVICE
# ============================================
# Currently using mock implementation
# Uncomment and configure when ready to use Africa's Talking

SMS_SENDER_ID=IET

# Africa's Talking (recommended for Tanzania - uncomment when ready)
# AT_API_KEY=your_africastalking_api_key
# AT_USERNAME=your_africastalking_username

# Twilio (alternative - uncomment when ready)
# TWILIO_ACCOUNT_SID=xxxx
# TWILIO_AUTH_TOKEN=xxxx
# TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# PAYMENT GATEWAYS
# ============================================
# All payment gateways are using mock implementation in development
# Configure the ones you need when ready

# --- M-Pesa Tanzania (Vodacom) ---
# MPESA_CONSUMER_KEY=your_mpesa_consumer_key
# MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
# MPESA_SHORTCODE=174379
# MPESA_PASSKEY=your_mpesa_passkey
# MPESA_CALLBACK_URL=https://api.iet.or.tz/api/v1/payments/webhooks/mpesa
# MPESA_ENVIRONMENT=sandbox

# --- Airtel Money ---
# AIRTEL_CLIENT_ID=your_airtel_client_id
# AIRTEL_CLIENT_SECRET=your_airtel_client_secret
# AIRTEL_ENVIRONMENT=sandbox
# AIRTEL_CALLBACK_URL=https://api.iet.or.tz/api/v1/payments/webhooks/airtel

# --- Tigo Pesa ---
# TIGO_ACCOUNT_ID=your_tigo_account_id
# TIGO_PIN=your_tigo_pin
# TIGO_CALLBACK_URL=https://api.iet.or.tz/api/v1/payments/webhooks/tigo

# --- Selcom (Card & Mobile Money Aggregator) ---
# SELCOM_API_KEY=your_selcom_api_key
# SELCOM_API_SECRET=your_selcom_api_secret
# SELCOM_VENDOR_ID=your_selcom_vendor_id
# SELCOM_CALLBACK_URL=https://api.iet.or.tz/api/v1/payments/webhooks/selcom

# --- DPO (Direct Pay Online - Bank/Card) ---
# DPO_COMPANY_TOKEN=your_dpo_company_token
# DPO_SERVICE_TYPE=your_service_type
# DPO_CALLBACK_URL=https://api.iet.or.tz/api/v1/payments/webhooks/dpo
# DPO_REDIRECT_URL=https://iet.or.tz/payment/complete

# ============================================
# FILE STORAGE - DigitalOcean Spaces (S3-compatible)
# ============================================
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_ENDPOINT=
DO_SPACES_REGION=sfo3
DO_SPACES_BUCKET=
DO_SPACES_CDN_URL=

# ============================================
# PUSH NOTIFICATIONS (optional)
# ============================================
# Firebase Cloud Messaging
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_PRIVATE_KEY=your_private_key
# FIREBASE_CLIENT_EMAIL=your_client_email

# OneSignal (alternative)
# ONESIGNAL_APP_ID=your_app_id
# ONESIGNAL_API_KEY=your_api_key
