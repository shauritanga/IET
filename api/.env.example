# ============================================
# IET Management System - Environment Configuration
# ============================================
# Copy this file to .env for native-host runs.
# Docker development also reads .env, but the defaults below are already safe
# for the local compose stack.

# Application
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
API_URL=http://localhost:3000/api/v1
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4000,http://127.0.0.1:4000,http://localhost:4100,http://127.0.0.1:4100,http://192.168.1.194:4000,http://192.168.1.194:4100

# ============================================
# DATABASE
# ============================================
DATABASE_ENABLED=true
DB_HOST=localhost
DB_PORT=5435
DB_USERNAME=postgres
DB_PASSWORD=dev_password
DB_NAME=iet_db

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=dev_jwt_secret_key_at_least_32_chars_long
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=dev_refresh_secret_key_at_least_32_chars
JWT_REFRESH_EXPIRATION=7d

# ============================================
# DEFAULT ADMIN SEED
# ============================================
ADMIN_EMAIL=shauritangaathanas@gmail.com
ADMIN_PASSWORD=Athanas@2015
ADMIN_FIRST_NAME=Athanas
ADMIN_LAST_NAME=Shauritanga
ADMIN_PHONE_NUMBER=255655591660

# ============================================
# RATE LIMITING
# ============================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ============================================
# ENCRYPTION (for 2FA secrets)
# ============================================
ENCRYPTION_KEY=dev_32_char_encryption_key_here!

# ============================================
# EMAIL SERVICE (cPanel Webmail / SMTP)
# ============================================
# Get SMTP settings from cPanel → Email Accounts → Connect Devices
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@iet.or.tz
EMAIL_FROM_NAME=IET Tanzania
# Set to false if cPanel uses a self-signed SSL certificate
SMTP_TLS_REJECT_UNAUTHORIZED=false

# ============================================
# SMS SERVICE
# ============================================
# Currently using mock implementation
# Uncomment and configure when ready to use Africa's Talking

SMS_SENDER_ID=IET

# Africa's Talking (recommended for Tanzania - uncomment when ready)
# AT_API_KEY=your_africastalking_api_key
# AT_USERNAME=your_africastalking_username

# Twilio (alternative - uncomment when ready)
# TWILIO_ACCOUNT_SID=xxxx
# TWILIO_AUTH_TOKEN=xxxx
# TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# PAYMENT GATEWAY - Selcom
# ============================================
# The platform processes all payments via Selcom hosted checkout (card +
# mobile money). Leave the keys blank in development to use the mock gateway;
# set SELCOM_API_KEY / SELCOM_API_SECRET / SELCOM_VENDOR to go live.
# Sandbox base: https://apigwtest2.selcommobile.com  Production: https://apigw.selcommobile.com
SELCOM_BASE_URL=https://apigwtest2.selcommobile.com
SELCOM_API_KEY=
SELCOM_API_SECRET=
SELCOM_VENDOR=
# Bearer token Selcom sends in the C2B webhook Authorization header
SELCOM_WEBHOOK_TOKEN=
SELCOM_TIMEOUT_MS=15000
# Where Selcom returns the buyer after payment; blank => members-portal callback
SELCOM_REDIRECT_URL=
SELCOM_CANCEL_URL=

# Application fee amounts (TZS)
APPLICATION_FEE_GRADUATE=500
APPLICATION_FEE_STANDARD=1000

# ============================================
# FILE STORAGE - DigitalOcean Spaces (S3-compatible)
# ============================================
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_ENDPOINT=
DO_SPACES_REGION=sfo3
DO_SPACES_BUCKET=
DO_SPACES_CDN_URL=

# ============================================
# PUSH NOTIFICATIONS (optional)
# ============================================
# Firebase Cloud Messaging
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_PRIVATE_KEY=your_private_key
# FIREBASE_CLIENT_EMAIL=your_client_email

# OneSignal (alternative)
# ONESIGNAL_APP_ID=your_app_id
# ONESIGNAL_API_KEY=your_api_key
